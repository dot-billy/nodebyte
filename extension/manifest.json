{
  "manifest_version": 3,
  "name": "Nodebyte",
  "description": "Add any website to your Nodebyte inventory with one click.",
  "version": "0.2.0",
  "permissions": ["activeTab", "storage", "bookmarks"],
  "host_permissions": ["http://*/api/*", "https://*/api/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
