COMPOSE_PROJECT_NAME=nodebyte

# PostgreSQL
POSTGRES_DB=nodebyte
POSTGRES_USER=nodebyte
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Backend
NODEBYTE_ENV=dev
JWT_SECRET=changeme-generate-a-random-string
JWT_ISSUER=nodebyte
ACCESS_TOKEN_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Set to "production" for production builds (next build + next start)
# NODE_ENV=production

# Set these when deploying to a real domain
# FRONTEND_ORIGIN=https://nodebyte.example.com
# NEXT_PUBLIC_API_BASE_URL=https://api.nodebyte.example.com

# NEXT_PUBLIC_EDITION=oss

# Set to false to disable public user registration (invite-only mode)
# REGISTRATION_ENABLED=false

# Cloudflare Turnstile (optional, test keys work out of the box)
# TURNSTILE_SECRET_KEY=your-secret-key
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-site-key
