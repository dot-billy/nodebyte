# Backend env (only needed when running outside Docker)
NODEBYTE_ENV=dev

# Database
DATABASE_URL=postgresql+asyncpg://nodebyte:changeme@localhost:5432/nodebyte

# Auth
JWT_SECRET=changeme-generate-a-random-string
JWT_ISSUER=nodebyte
ACCESS_TOKEN_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=30

# Cookies (tighten in production: COOKIE_SECURE=true)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Cloudflare Turnstile (optional)
# TURNSTILE_ENABLED=true
# TURNSTILE_SECRET_KEY=your-secret-key
